Bootstrap: docker
From: nvidia/cuda:12.4.1-devel-ubuntu22.04
Stage: build

%files
    pyproject.toml /opt/tomocupy/pyproject.toml
    VERSION        /opt/tomocupy/VERSION
    README.rst     /opt/tomocupy/README.rst
    LICENSE        /opt/tomocupy/LICENSE
    CMakeLists.txt /opt/tomocupy/CMakeLists.txt
    src            /opt/tomocupy/src

%post
    set -eux
    export DEBIAN_FRONTEND=noninteractive
    export PYTHON_VERSION=3.11
    export CUPY_PACKAGE=cupy-cuda12x

    apt-get update
    apt-get install -y --no-install-recommends \
        software-properties-common ca-certificates curl git
    add-apt-repository -y ppa:deadsnakes/ppa
    apt-get update
    apt-get install -y --no-install-recommends \
        python${PYTHON_VERSION} python${PYTHON_VERSION}-dev python${PYTHON_VERSION}-venv \
        build-essential cmake ninja-build swig pkg-config \
        libgl1 libglib2.0-0 libgomp1
    ln -sf /usr/bin/python${PYTHON_VERSION} /usr/local/bin/python3
    ln -sf /usr/bin/python${PYTHON_VERSION} /usr/local/bin/python

    curl -LsSf https://astral.sh/uv/install.sh | env UV_INSTALL_DIR=/usr/local/bin sh

    uv venv --python python${PYTHON_VERSION} /opt/venv
    /opt/venv/bin/python -m ensurepip --upgrade || true

    cd /opt/tomocupy
    uv pip install --python /opt/venv/bin/python "${CUPY_PACKAGE}" .

    find /opt/venv -name '__pycache__' -type d -prune -exec rm -rf {} +
    apt-get purge -y build-essential cmake ninja-build swig pkg-config \
        python${PYTHON_VERSION}-dev curl git software-properties-common
    apt-get autoremove -y
    rm -rf /var/lib/apt/lists/*

%environment
    export VIRTUAL_ENV=/opt/venv
    export PATH=/opt/venv/bin:/usr/local/bin:/usr/bin:/bin

%runscript
    exec tomocupy "$@"

%labels
    Author     Argonne National Laboratory
    Package    tomocupy
    CudaBase   12.4.1
    PythonVer  3.11
    Cupy       cupy-cuda12x

%help
    tomocupy: GPU-based tomographic and laminographic reconstruction.

    Build:
        apptainer build tomocupy.sif apptainer.def

    Run (requires --nv for GPU access):
        apptainer run --nv tomocupy.sif recon -h
        apptainer run --nv -B /scratch/data:/data tomocupy.sif recon \
            --file-name /data/sample.h5 [...]
